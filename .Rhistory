cat("\nFitting all 10 IMD deciles...\n")
all_fits <- lapply(1:10, function(d) {
fit <- fit_decile(imd_decile = d, n_samples = 2000, n_chains = 3)
if (!is.null(fit)) {
saveRDS(fit, paste0("output/fitting/fitted_samples_imd", d, ".rds"))
}
fit
})
